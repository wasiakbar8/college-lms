rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admins collection — only the admin themselves can read their own doc
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // only writable via Firebase Console or seed script
    }

    // Students — admin can read/write all; student can only read/update their own
    match /students/{uid} {
      allow read: if request.auth != null &&
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || request.auth.uid == uid);
      allow create: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow update: if request.auth != null && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.uid == uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['phone','address']))
      );
      allow delete: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Courses — admin writes; students can read
    match /courses/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Attendance — admin writes; student reads own by rollNo (enforced client-side)
    match /attendance/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Results — admin writes; students can read
    match /results/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Fees — admin writes; students can read
    match /fees/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Timetable — admin writes; students can read
    match /timetable/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
  }
}
